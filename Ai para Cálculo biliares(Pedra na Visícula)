        "# **Preparação dos Conjuntos**\n",
        ">Os trechos de código a seguir servem para separar os conjuntos de treinamento e teste,sendo separado, aleatoriamente, 75 % das amostras para treinamento (train) e 25 % para teste (test)."
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# [2] Formação dos conjuntos de treinamento e teste\n",
        "# Convenção: a coluna alvo (rótulo) chama-se \"class\" (ajuste se necessário).\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.compose import ColumnTransformer\n",
        "from sklearn.preprocessing import OneHotEncoder, StandardScaler, LabelEncoder\n",
        "\n",
        "TARGET_COL = \"Diabetes Mellitus (DM)\"  # <- ajuste se a coluna alvo tiver outro nome\n",
        "\n",
        "if TARGET_COL not in table.columns:\n",
        "    raise ValueError(f'Coluna alvo \"{TARGET_COL}\" não encontrada. Colunas disponíveis: {list(table.columns)}')\n",
        "\n",
        "X = table.drop(columns=[TARGET_COL])\n",
        "y_str = table[TARGET_COL].astype(str)  # Temporariamente como string para o LabelEncoder\n",
        "\n",
        "# Codificar a variável alvo y para inteiros\n",
        "le = LabelEncoder()\n",
        "y = le.fit_transform(y_str)\n",
        "\n",
        "# Converter colunas de objeto para numérico, tratando vírgulas como decimais e NaNs\n",
        "for col in X.select_dtypes(include=['object']).columns:\n",
        "    # Tenta converter para numérico, substituindo vírgula por ponto primeiro\n",
        "    # Usando errors='coerce' transforma valores não conversíveis em NaN\n",
        "    X[col] = pd.to_numeric(X[col].astype(str).replace(',', '.'), errors='coerce')\n",
        "\n",
        "# Preencher quaisquer NaNs criados durante a conversão (e.g., se alguns valores eram verdadeiramente não-numéricos ou vazios)\n",
        "# Para simplificar, preenchendo com a mediana, mas uma estratégia de imputação mais sofisticada pode ser usada.\n",
        "# Apenas preencher NaNs em colunas numéricas\n",
        "for col in X.select_dtypes(include=['number']).columns:\n",
        "    if X[col].isnull().any():\n",
        "        X[col] = X[col].fillna(X[col].median())\n",
        "\n",
        "# Detecta colunas numéricas e categóricas automaticamente após a limpeza\n",
        "num_cols = X.select_dtypes(include=[\"number\"]).columns.tolist()\n",
        "cat_cols = [c for c in X.columns if c not in num_cols]\n",
        "\n",
        "print(\"Colunas numéricas:\", num_cols)\n",
        "print(\"Colunas categóricas:\", cat_cols)\n",
        "\n",
        "# Pré-processamento:\n",
        "# - numéricas: padronização (média 0, desvio 1)\n",
        "# - categóricas: One-Hot Encoding (evita impor ordem artificial como no OrdinalEncoder)\n",
        "preprocess = ColumnTransformer(\n",
        "    transformers=[\n",
        "        (\"num\", StandardScaler(), num_cols),\n",
        "        (\"cat\", OneHotEncoder(handle_unknown=\"ignore\"), cat_cols),\n",
        "    ],\n",
        "    remainder=\"drop\"\n",
        ")\n",
        "\n",
        "# Separação treino/teste\n",
        "train_X, test_X, train_y, test_y = train_test_split(\n",
        "    X, y, test_size=0.25, random_state=42, stratify=y\n",
        ")\n",
        "\n",
        "print(\"Treino:\", train_X.shape, \"Teste:\", test_X.shape)\n"
      ],
